# ====================================================================
# 1. 系统与开发环境 (禁止上传)
# ====================================================================
venv/
.venv/
__pycache__/
*.py[cod]
*$py.class
.DS_Store
Thumbs.db
*.log
.vscode/
.idea/

# ====================================================================
# 2. 机器学习权重与产物 (仅保留代码，不保留超大模型)
# ====================================================================
# 忽略所有 PyTorch 权重（建议手动给队友发 .pt 文件）
*.pt
*.pth
*.onnx
*.tflite

# 忽略训练过程中的日志、图表和权重目录
/algorithm/runs/
.ultralytics/

# ====================================================================
# 3. 数据集与图像管理 (管理员核心：禁止大数据冲垮仓库)
# ====================================================================
# 忽略 YOLO 训练用的数据集（包含 images 和 labels 文件夹）
/algorithm/datasets/
/pict/

# 忽略所有常见的文档、图像和压缩包格式
*.jpg
*.jpeg
*.png
*.heic
*.zip
*.rar
*.tar.gz

# ====================================================================
# 4. 光谱数据管理 (针对队友的部分)
# ====================================================================
# 忽略光谱原始数据 CSV（如果数据量很大或包含隐私）
# 如果需要保留少量示例数据，可以取消注释下面的例外规则
*.csv

# ====================================================================
# 5. 例外规则 (确保关键配置文件不被误伤)
# ====================================================================
# 必须保留依赖清单，方便队友一键配环境
!requirements.txt

# ====================================================================
# 6. 其他模块 (硬件与小程序)
# ====================================================================
/firmware/.pio/
/miniprogram/node_modules/

# --- 个人文档与非公开资料 ---
# 屏蔽名为 "docs_local" 的整个文件夹（推荐：所有不想上传的文档都扔进去）
docs_local/